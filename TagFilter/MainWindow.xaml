<Window x:Class="TagFilter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LoRA Dataset Tag Editor" Height="720" Width="1280"
        Background="#1E1E2E">

    <Window.Resources>
        <SolidColorBrush x:Key="BgBase"      Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BgSurface"   Color="#2A2A3E"/>
        <SolidColorBrush x:Key="BgPanel"     Color="#313149"/>
        <SolidColorBrush x:Key="AccentBlue"  Color="#89B4FA"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#A6E3A1"/>
        <SolidColorBrush x:Key="AccentRed"   Color="#F38BA8"/>
        <SolidColorBrush x:Key="TextMain"    Color="#CDD6F4"/>
        <SolidColorBrush x:Key="TextSub"     Color="#6C7086"/>

        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Foreground"      Value="{StaticResource TextMain}"/>
            <Setter Property="Background"      Value="{StaticResource BgPanel}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="#1E1E2E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Foreground"               Value="{StaticResource TextMain}"/>
            <Setter Property="Background"               Value="{StaticResource BgPanel}"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="Padding"                  Value="8,5,4,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>
                            <Popup x:Name="PART_Popup" Grid.ColumnSpan="2"
                                   AllowsTransparency="True"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                   Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="{StaticResource BgPanel}"
                                        BorderBrush="{StaticResource AccentBlue}"
                                        BorderThickness="1" CornerRadius="4"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                        Padding="2">
                                    <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                            <Border Grid.ColumnSpan="2" Background="{TemplateBinding Background}" CornerRadius="6"/>
                            <ContentPresenter Grid.Column="0"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" IsHitTestVisible="False"/>
                            <ToggleButton Grid.ColumnSpan="2" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <TextBlock Grid.Column="1" Text="▾"
                                       Foreground="{StaticResource TextSub}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding"    Value="10,6"/>
                        <Setter Property="Cursor"     Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}" CornerRadius="3">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBlue}"/>
                                            <Setter Property="Foreground" Value="#1E1E2E"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3D3D5C"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CategoryToggle" TargetType="ToggleButton">
            <Setter Property="Foreground"      Value="{StaticResource TextMain}"/>
            <Setter Property="Background"      Value="{StaticResource BgPanel}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,0,4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="#1E1E2E"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TagChipSmall" TargetType="Border">
            <Setter Property="Background"   Value="{StaticResource BgPanel}"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding"      Value="5,2"/>
            <Setter Property="Margin"       Value="2,1"/>
        </Style>

        <Style x:Key="ImageListItem" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Padding"    Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="2" Padding="4">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BgPanel}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background"      Value="#3D3D5C"/>
                                <Setter TargetName="border" Property="BorderBrush"     Value="{StaticResource AccentBlue}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AllListItem" TargetType="ListViewItem">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="Foreground"             Value="{StaticResource TextMain}"/>
            <Setter Property="Padding"                Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="0">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D3D5C"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E2E48"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- NumericTextBox: 数値入力ボックス共通 -->
        <Style x:Key="NumericBox" TargetType="TextBox">
            <Setter Property="Background"    Value="{StaticResource BgPanel}"/>
            <Setter Property="Foreground"    Value="{StaticResource TextMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"       Value="6,5"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="CaretBrush"    Value="{StaticResource AccentBlue}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ══ ツールバー（2段構成） ══ -->
        <Border Grid.Row="0" Background="{StaticResource BgSurface}">
            <DockPanel VerticalAlignment="Center" Margin="12,0">

                <!-- 右：閾値 + プログレス -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Text="閾値:" Foreground="{StaticResource TextSub}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Slider x:Name="SliderThreshold" Minimum="0.1" Maximum="0.9" Value="0.35"
                            Width="80" VerticalAlignment="Center"
                            Foreground="{StaticResource AccentBlue}"/>
                    <TextBlock Foreground="{StaticResource AccentBlue}"
                               VerticalAlignment="Center" Margin="4,0,16,0" Width="32"
                               Text="{Binding ElementName=SliderThreshold, Path=Value, StringFormat={}{0:F2}}"/>
                    <ProgressBar x:Name="ProgressBar" Width="140" Height="8"
                                 Visibility="Collapsed"
                                 Foreground="{StaticResource AccentGreen}"
                                 Background="{StaticResource BgPanel}"/>
                    <TextBlock x:Name="TxtProgress" Foreground="{StaticResource TextSub}"
                               VerticalAlignment="Center" Margin="6,0,0,0" Visibility="Collapsed"/>
                </StackPanel>

                <!-- 左：基本操作 + 推論設定 -->
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnOpenFolder" Content="フォルダを開く"
                            Style="{StaticResource FlatButton}"
                            Click="BtnOpenFolder_Click" Margin="0,0,6,0"/>
                    <Button x:Name="BtnSaveAll" Content="全て保存"
                            Style="{StaticResource FlatButton}"
                            Click="BtnSaveAll_Click" Margin="0,0,12,0"/>

                    <Separator Width="1" Background="{StaticResource BgPanel}" Margin="0,8,12,8"/>

                    <!-- 推論カテゴリ -->
                    <TextBlock Text="推論:" Foreground="{StaticResource TextSub}"
                               VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11"/>
                    <ComboBox x:Name="CmbLoraMode" Style="{StaticResource DarkComboBox}"
                              Width="130" Margin="0,0,12,0" VerticalAlignment="Center"/>

                    <Separator Width="1" Background="{StaticResource BgPanel}" Margin="0,8,12,8"/>

                    <!-- デバイス選択 -->
                    <TextBlock Text="デバイス:" Foreground="{StaticResource TextSub}"
                               VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11"/>
                    <ComboBox x:Name="CmbDevice" Style="{StaticResource DarkComboBox}"
                              Width="80" Margin="0,0,8,0" VerticalAlignment="Center"
                              SelectionChanged="CmbDevice_SelectionChanged">
                        <ComboBoxItem Content="自動"/>
                        <ComboBoxItem Content="GPU"/>
                        <ComboBoxItem Content="CPU"/>
                    </ComboBox>
                    <!-- GPU可否インジケータ -->
                    <Border x:Name="GpuIndicator"
                            CornerRadius="3" Padding="6,3" Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="TxtGpuStatus" FontSize="10"
                                   Foreground="#1E1E2E" Text="確認中..."/>
                    </Border>

                    <Separator Width="1" Background="{StaticResource BgPanel}" Margin="0,8,12,8"/>

                    <!-- 並列処理数 -->
                    <TextBlock Text="並列数:" Foreground="{StaticResource TextSub}"
                               VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11"/>
                    <Button Content="-" Width="24" Height="24"
                            Style="{StaticResource FlatButton}" Padding="0"
                            Click="BtnParallelMinus_Click"/>
                    <TextBox x:Name="TxtParallel" Width="36" Height="24"
                             Style="{StaticResource NumericBox}"
                             Margin="2,0" Text="1"
                             PreviewTextInput="TxtParallel_PreviewTextInput"/>
                    <Button Content="+" Width="24" Height="24"
                            Style="{StaticResource FlatButton}" Padding="0"
                            Click="BtnParallelPlus_Click" Margin="0,0,12,0"/>

                    <Separator Width="1" Background="{StaticResource BgPanel}" Margin="0,8,12,8"/>

                    <Button x:Name="BtnAutoTag" Content="自動タグ付け"
                            Style="{StaticResource FlatButton}"
                            Click="BtnAutoTag_Click"
                            Background="{StaticResource AccentBlue}"
                            Foreground="#1E1E2E"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══ メインコンテンツ ══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左ペイン：画像一覧 -->
            <Border Grid.Column="0" Background="{StaticResource BgSurface}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource BgBase}" Padding="10,0">
                        <TextBlock x:Name="TxtImageCount" Text="0 件"
                                   Foreground="{StaticResource TextSub}"
                                   VerticalAlignment="Center" FontSize="12"/>
                    </Border>
                    <ListView x:Name="ImageList" Grid.Row="1"
                              Background="Transparent" BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              ItemContainerStyle="{StaticResource ImageListItem}"
                              SelectionChanged="ImageList_SelectionChanged"
                              SelectionMode="Extended">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Vertical" Width="188">
                                    <Border CornerRadius="4" ClipToBounds="True" Height="140">
                                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>
                                    </Border>
                                    <TextBlock Text="{Binding FileName}"
                                               Foreground="{StaticResource TextMain}" FontSize="11"
                                               TextTrimming="CharacterEllipsis" Margin="2,4,2,0"/>
                                    <TextBlock Text="{Binding TagCount, StringFormat={}{0} tags}"
                                               Foreground="{StaticResource TextSub}"
                                               FontSize="10" Margin="2,1,2,2"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4"
                          Background="{StaticResource BgBase}"
                          HorizontalAlignment="Stretch"/>

            <!-- 右ペイン -->
            <Grid Grid.Column="2" Background="{StaticResource BgBase}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 行1：表示フィルタ -->
                <Border Grid.Row="0" Background="{StaticResource BgSurface}" Padding="10,7">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="表示フィルタ:" Foreground="{StaticResource TextSub}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"/>
                        <ToggleButton x:Name="FilterAll"    Content="すべて" IsChecked="True"
                                      Style="{StaticResource CategoryToggle}" Tag="All"/>
                        <ToggleButton x:Name="FilterFace"   Content="顔"
                                      Style="{StaticResource CategoryToggle}" Tag="Face"/>
                        <ToggleButton x:Name="FilterBody"   Content="体"
                                      Style="{StaticResource CategoryToggle}" Tag="Body"/>
                        <ToggleButton x:Name="FilterOutfit" Content="服装"
                                      Style="{StaticResource CategoryToggle}" Tag="Outfit"/>
                        <ToggleButton x:Name="FilterPose"   Content="ポーズ"
                                      Style="{StaticResource CategoryToggle}" Tag="Pose"/>
                        <ToggleButton x:Name="FilterBg"     Content="背景"
                                      Style="{StaticResource CategoryToggle}" Tag="Background"/>
                        <ToggleButton x:Name="FilterStyle"  Content="スタイル"
                                      Style="{StaticResource CategoryToggle}" Tag="Style"/>
                        <ToggleButton x:Name="FilterOther"  Content="その他"
                                      Style="{StaticResource CategoryToggle}" Tag="Other"/>
                    </StackPanel>
                </Border>

                <!-- 行2：一括操作 -->
                <Border Grid.Row="1" Background="{StaticResource BgBase}"
                        BorderBrush="{StaticResource BgSurface}" BorderThickness="0,1,0,1"
                        Padding="10,6">
                    <DockPanel>
                        <Button x:Name="BtnBulkDeleteCategory"
                                DockPanel.Dock="Right"
                                Content="選択中カテゴリを削除"
                                Style="{StaticResource FlatButton}"
                                Click="BtnBulkDeleteCategory_Click"
                                Foreground="{StaticResource AccentRed}"
                                IsEnabled="False"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="一括挿入（全画像）:"
                                       Foreground="{StaticResource TextSub}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"/>
                            <TextBox x:Name="TxtBulkTag" Width="180"
                                     Background="{StaticResource BgPanel}"
                                     Foreground="{StaticResource TextMain}"
                                     BorderThickness="0" Padding="8,5" FontSize="12"
                                     CaretBrush="{StaticResource AccentBlue}"
                                     KeyDown="TxtBulkTag_KeyDown"/>
                            <Button Content="挿入"
                                    Style="{StaticResource FlatButton}"
                                    Click="BtnBulkInsert_Click"
                                    Foreground="{StaticResource AccentGreen}"
                                    Margin="6,0,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- 行3：全ファイル一覧 -->
                <ListView x:Name="AllItemsListView"
                          Grid.Row="2"
                          Background="Transparent" BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          ItemContainerStyle="{StaticResource AllListItem}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BgSurface}"
                                    BorderThickness="0,0,0,1" Padding="6,6">
                                <DockPanel>
                                    <Border DockPanel.Dock="Left"
                                            Width="64" Height="64"
                                            CornerRadius="4" ClipToBounds="True"
                                            Margin="0,0,10,0">
                                        <Image Source="{Binding Item.Thumbnail}" Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel DockPanel.Dock="Left"
                                                Width="130" VerticalAlignment="Top"
                                                Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Item.FileName}"
                                                   Foreground="{StaticResource TextMain}"
                                                   FontSize="11" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Item.TagCount, StringFormat={}{0} tags}"
                                                   Foreground="{StaticResource AccentBlue}"
                                                   FontSize="10" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding FilteredTags}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource TagChipSmall}"
                                                        BorderThickness="2,0,0,0"
                                                        BorderBrush="{Binding CategoryColor}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="{StaticResource TextMain}"
                                                                   FontSize="11"/>
                                                        <TextBlock Text=" [x]"
                                                                   Foreground="{StaticResource AccentRed}"
                                                                   FontSize="10" Cursor="Hand"
                                                                   Tag="{Binding}"
                                                                   MouseLeftButtonDown="ListViewTagDelete_Click"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- 行4：タグ追加 -->
                <Border Grid.Row="3" Background="{StaticResource BgSurface}" Padding="12,8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left"
                                   Text="選択画像にタグを追加:"
                                   Foreground="{StaticResource TextSub}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"/>
                        <Button DockPanel.Dock="Right" Content="追加"
                                Style="{StaticResource FlatButton}"
                                Click="BtnAddTag_Click"
                                Background="{StaticResource AccentBlue}"
                                Foreground="#1E1E2E" Margin="8,0,0,0"/>
                        <TextBox x:Name="TxtNewTag"
                                 Background="{StaticResource BgPanel}"
                                 Foreground="{StaticResource TextMain}"
                                 BorderThickness="0" Padding="8,6" FontSize="13"
                                 KeyDown="TxtNewTag_KeyDown"
                                 CaretBrush="{StaticResource AccentBlue}"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ステータスバー -->
        <Border Grid.Row="2" Background="{StaticResource BgSurface}" Padding="12,0">
            <DockPanel>
                <TextBlock x:Name="TxtStatus" DockPanel.Dock="Left" Text="準備完了"
                           Foreground="{StaticResource TextSub}"
                           VerticalAlignment="Center" FontSize="11"/>
                <TextBlock x:Name="TxtSelectedCount" DockPanel.Dock="Right"
                           Foreground="{StaticResource TextSub}"
                           VerticalAlignment="Center" FontSize="11"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>